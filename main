<script>
// ── AUTH ──
const ADMINS=[{email:'wdeclercq@thacher.org',pass:'Thacher',name:'W. DeClerq'},{email:'awayner@thacher.org',pass:'Thacher',name:'A. Wayner'}];
let currentUser=null,isAdmin=false;
 
function doLogin(){
 const email=document.getElementById('login-email').value.trim().toLowerCase();
 const pass=document.getElementById('login-pass').value;
 const err=document.getElementById('login-error');
 const admin=ADMINS.find(a=>a.email===email&&a.pass===pass);
 if(admin){currentUser=admin;isAdmin=true;err.style.display='none';showAdmin();}
 else{err.style.display='block';}
}
document.getElementById('login-pass').addEventListener('keydown',e=>{if(e.key==='Enter')doLogin();});
function guestAccess(){currentUser={name:'Guest'};isAdmin=false;showPublic();}
function signOut(){
 currentUser=null;isAdmin=false;
 document.getElementById('login-screen').classList.add('active');
 document.getElementById('public-screen').classList.remove('active');
 document.getElementById('admin-screen').classList.remove('active');
 document.getElementById('login-email').value='';
 document.getElementById('login-pass').value='';
}
function showPublic(){
 document.getElementById('login-screen').classList.remove('active');
 document.getElementById('public-screen').classList.add('active');
 document.getElementById('admin-screen').classList.remove('active');
 document.getElementById('admin-nav-btn').style.display=isAdmin?'':'none';
 renderGallery();
}
function showAdmin(){
 document.getElementById('login-screen').classList.remove('active');
 document.getElementById('public-screen').classList.remove('active');
 document.getElementById('admin-screen').classList.add('active');
 document.getElementById('admin-user-name').textContent=currentUser.name;
 updateAdminStats();
 renderManageTable('');
}
function switchToAdmin(){if(isAdmin)showAdmin();}
function switchToPublic(){showPublic();}
 
