function loadInterviews(){
 try{const r=localStorage.getItem(STORE_KEY);if(r)return JSON.parse(r);}catch(e){}
 localStorage.setItem(STORE_KEY,JSON.stringify(SEED));
 return JSON.parse(JSON.stringify(SEED));
}
function saveInterviews(arr){localStorage.setItem(STORE_KEY,JSON.stringify(arr));}
function getInterviews(){return loadInterviews();}
 
// ── BUILD INDEX ──
function buildIndex(interviews){
 const idx={};
 interviews.forEach(d=>{
   const text=`${d.title} ${d.abstract} ${(d.tags||[]).join(' ')} ${d.subject} ${d.student} ${d.category}`.toLowerCase();
   text.split(/\W+/).filter(w=>w.length>2).forEach(w=>{
     if(!idx[w])idx[w]=new Set();
     idx[w].add(d.id);
   });
 });
 return idx;
}
function highlight(text,words){
 if(!words.length)return text;
 let out=text;
 words.forEach(w=>{if(w.length<2)return;out=out.replace(new RegExp(`(${w.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')})`, 'gi'),'<mark>$1</mark>');});
 return out;
}
 
// ── PUBLIC GALLERY ──
let activeFilter='all';
function setFilter(cat,btn){
 activeFilter=cat;
 document.querySelectorAll('.chip').forEach(c=>c.classList.remove('active'));
 btn.classList.add('active');
 renderGallery();
}
const CAT_ORDER=['Immigration','Civil Rights & Activism','Railroads & West','Politics','Effects of War','Natural Disasters','Communism History','Financial Crisis','Family','Education','Medicine',"Women's History",'Music & Culture','Thacher History','LGBTQ+ History','Aviation','Other'];
const OTHER_CATS=new Set(['Railroads & West','Politics','Natural Disasters','Communism History','Music & Culture','Thacher History','Aviation']);
 
function renderGallery(){
 const interviews=getInterviews();
 const idx=buildIndex(interviews);
 const q=document.getElementById('pub-search').value.trim().toLowerCase();
 const words=q?q.split(/\W+/).filter(w=>w.length>2):[];
 let visible=interviews;
 if(words.length){
   const scores={};
   words.forEach(w=>{Object.keys(idx).forEach(k=>{if(k.includes(w)){const boost=k===w?3:1;idx[k].forEach(id=>{scores[id]=(scores[id]||0)+boost;});}});});
   visible=interviews.filter(d=>scores[d.id]).sort((a,b)=>(scores[b.id]||0)-(scores[a.id]||0));
 }
 if(activeFilter!=='all'){
   if(activeFilter==='Other')visible=visible.filter(d=>OTHER_CATS.has(d.category));
   else visible=visible.filter(d=>d.category===activeFilter);
 }
 document.getElementById('pub-count').textContent=`${visible.length} of ${interviews.length} interviews`;
 const groups={};
 visible.forEach(d=>{if(!groups[d.category])groups[d.category]=[];groups[d.category].push(d);});
 const newestIds=new Set(interviews.filter(d=>d.source==='added').map(d=>d.id));
 let html='';
 if(!visible.length){
   html=`<div class="empty"><div class="empty-title">No interviews found</div><p>Try a different keyword or clear the filter.</p></div>`;
 } else {
   CAT_ORDER.forEach(cat=>{
     if(!groups[cat]?.length)return;
     const items=groups[cat];
     html+=`<div class="section-head"><div class="section-name">${cat}</div><div class="section-line"></div><div class="section-count">${items.length} interview${items.length>1?'s':''}</div></div><div class="cards">`;
     items.forEach((d,i)=>{
       html+=`<div class="card${newestIds.has(d.id)?' is-new':''}" style="animation-delay:${i*.04}s" onclick="openModal(${d.id})">
         <div class="card-cat">${d.category}</div>
         <div class="card-title">${highlight(d.title,words)}</div>
         <div class="card-student">by ${d.student} · subject: ${d.subject.split('(')[0].trim()}</div>
         <div class="card-abstract">${highlight((d.abstract||'').slice(0,280)+'…',words)}</div>
         <div class="card-footer">${(d.tags||[]).slice(0,3).map(t=>`<span class="tag">${t}</span>`).join('')}${d.audio?'<span class="has-audio">Audio</span>':''}</div>
       </div>`;
     });
     html+=`</div>`;
   });
   Object.keys(groups).forEach(cat=>{
     if(CAT_ORDER.includes(cat))return;
     const items=groups[cat];
     html+=`<div class="section-head"><div class="section-name">${cat}</div><div class="section-line"></div><div class="section-count">${items.length}</div></div><div class="cards">`;
     items.forEach((d,i)=>{html+=`<div class="card${newestIds.has(d.id)?' is-new':''}" style="animation-delay:${i*.04}s" onclick="openModal(${d.id})"><div class="card-cat">${d.category}</div><div class="card-title">${d.title}</div><div class="card-student">by ${d.student} · subject: ${d.subject.split('(')[0].trim()}</div><div class="card-abstract">${(d.abstract||'').slice(0,280)}…</div><div class="card-footer">${(d.tags||[]).slice(0,3).map(t=>`<span class="tag">${t}</span>`).join('')}${d.audio?'<span class="has-audio">Audio</span>':''}</div></div>`;});
     html+=`</div>`;
   });
 }
 document.getElementById('pub-main').innerHTML=html;
}
 
function openModal(id){
 const d=getInterviews().find(x=>x.id===id);
 if(!d)return;
 document.getElementById('m-cat').textContent=d.category;
 document.getElementById('m-title').textContent=d.title;
 document.getElementById('m-student').textContent=`Interviewed by ${d.student} · Subject: ${d.subject}`;
 document.getElementById('m-abstract').textContent=d.abstract;
 document.getElementById('m-tags').innerHTML=(d.tags||[]).map(t=>`<span class="tag">${t}</span>`).join('');
 const audio=document.getElementById('m-audio');
 audio.style.display=d.audio?'flex':'none';
 audio.textContent=d.audioName?`♪ Audio recording: ${d.audioName}`:'♪ Audio recording available';
 document.getElementById('overlay').classList.add('open');
}
function closeModal(e){if(e.target===document.getElementById('overlay'))document.getElementById('overlay').classList.remove('open');}
document.addEventListener('keydown',e=>{if(e.key==='Escape')document.getElementById('overlay').classList.remove('open');});
 
// ── ADMIN ──
function showAdminPanel(name,btn){
 document.querySelectorAll('.admin-panel').forEach(p=>p.classList.remove('active'));
 document.querySelectorAll('.admin-nav-item').forEach(b=>b.classList.remove('active'));
 document.getElementById('panel-'+name).classList.add('active');
 if(btn)btn.classList.add('active');
 const titles={upload:'Upload Interview',manage:'All Interviews'};
 document.getElementById('admin-page-title').textContent=titles[name]||name;
 if(name==='manage')renderManageTable(document.getElementById('manage-filter')?.value||'');
 updateAdminStats();
}
 
function updateAdminStats(){
 const all=getInterviews();
 const added=all.filter(d=>d.source==='added');
 const withAudio=all.filter(d=>d.audio);
 const cats=new Set(all.map(d=>d.category));
 document.getElementById('admin-stats-row').innerHTML=`
   <div class="astat"><div class="astat-val">${all.length}</div><div class="astat-label">Total Interviews</div></div>
   <div class="astat"><div class="astat-val">${added.length}</div><div class="astat-label">Admin Added</div></div>
   <div class="astat"><div class="astat-val">${withAudio.length}</div><div class="astat-label">With Audio</div></div>
   <div class="astat"><div class="astat-val">${cats.size}</div><div class="astat-label">Categories</div></div>`;
 document.getElementById('admin-stats-mini').textContent=`${all.length} total · ${added.length} added by admin`;
}
 
function submitInterview(){
 const student=document.getElementById('f-student').value.trim();
 const subject=document.getElementById('f-subject').value.trim();
 const title=document.getElementById('f-title').value.trim();
 const category=document.getElementById('f-category').value;
 const abstract=document.getElementById('f-abstract').value.trim();
 const tagsRaw=document.getElementById('f-tags').value;
 const audio=document.getElementById('f-audio').checked;
 const audioName=document.getElementById('f-audio-name').value.trim();
 if(!student||!subject||!title||!category||!abstract){alert('Please fill in all required fields (marked with *).');return;}
 const tags=tagsRaw.split(',').map(t=>t.trim()).filter(Boolean);
 const all=getInterviews();
 const newId=Math.max(...all.map(d=>d.id),0)+1;
 all.push({id:newId,category,student,subject,title,abstract,tags,audio,audioName,source:'added',addedBy:currentUser.name,addedAt:new Date().toLocaleDateString()});
 saveInterviews(all);
 document.getElementById('upload-success').classList.add('show');
 setTimeout(()=>document.getElementById('upload-success').classList.remove('show'),3500);
 clearForm();
 updateAdminStats();
}
 
function clearForm(){
 ['f-student','f-subject','f-title','f-tags','f-abstract','f-audio-name'].forEach(id=>{document.getElementById(id).value='';});
 document.getElementById('f-category').value='';
 document.getElementById('f-audio').checked=false;
}
 
function renderManageTable(filter){
 const all=getInterviews();
 const q=filter.toLowerCase();
 const shown=q?all.filter(d=>d.title.toLowerCase().includes(q)||d.student.toLowerCase().includes(q)||d.subject.toLowerCase().includes(q)||d.category.toLowerCase().includes(q)):all;
 document.getElementById('manage-count').textContent=all.length;
 document.getElementById('manage-tbody').innerHTML=shown.map(d=>`
   <tr>
     <td><div class="td-title">${d.title}</div></td>
     <td><div class="td-cat">${d.category}</div></td>
     <td><div class="td-mono">${d.student}</div></td>
     <td><span class="td-badge ${d.source==='added'?'badge-added':'badge-original'}">${d.source==='added'?'Admin added':'Original'}</span></td>
     <td><div class="td-mono">${d.audio?'✓':'-'}</div></td>
     <td>${d.source==='added'?`<button class="btn-delete" onclick="deleteInterview(${d.id})" title="Delete">✕</button>`:''}</td>
   </tr>`).join('');
}
 
function deleteInterview(id){
 if(!confirm('Remove this interview from the gallery?'))return;
 saveInterviews(getInterviews().filter(d=>d.id!==id));
 renderManageTable(document.getElementById('manage-filter')?.value||'');
 updateAdminStats();
}
</script>
